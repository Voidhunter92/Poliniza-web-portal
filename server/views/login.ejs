<%- include('partials/head', { title: 'Ingresar' }) %>
<div class="portal-login">
  <div class="portal-login__card">
    <img src="/assets/img/logo-apaisado.png" alt="Poliniza" class="portal-login__logo" />
    <h1>Portal de clientes</h1>
    <p class="sub">Ingresá con el usuario y la contraseña que te asignamos.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/portal/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="field">
        <label for="username">Usuario</label>
        <input type="text" id="username" name="username" autocomplete="username" required autofocus value="<%= username || '' %>" />
      </div>
      <div class="field">
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required />
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn--primary">Ingresar</button>
      </div>
    </form>
  </div>
</div>
<%- include('partials/foot') %>
