<%- include('partials/head', { title: 'Cambiar contraseña' }) %>
<div class="portal-shell">
  <%- include('partials/topbar', { user }) %>
  <main class="portal-main" style="max-width:480px;">
    <div class="portal-header"><h1>Cambiar mi contraseña</h1></div>

    <div class="portal-card">
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

      <form method="POST" action="/portal/cambiar-password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="field">
          <label for="actual">Contraseña actual</label>
          <input type="password" id="actual" name="actual" required autocomplete="current-password" />
        </div>
        <div class="field">
          <label for="nueva">Nueva contraseña</label>
          <input type="password" id="nueva" name="nueva" required minlength="6" autocomplete="new-password" />
          <p class="field-hint">Mínimo 6 caracteres.</p>
        </div>
        <div class="field">
          <label for="repetir">Repetir nueva contraseña</label>
          <input type="password" id="repetir" name="repetir" required minlength="6" autocomplete="new-password" />
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn--primary">Guardar</button>
        </div>
      </form>
    </div>
  </main>
</div>
<%- include('partials/foot') %>
