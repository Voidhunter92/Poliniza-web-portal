<%- include('../partials/head', { title: 'Clientes' }) %>
<div class="portal-shell">
  <%- include('../partials/topbar', { user, adminTabs, activeTab }) %>
  <main class="portal-main">
    <div class="portal-header">
      <div>
        <h1>Cuentas de clientes</h1>
        <p>Creá y administrá los accesos de tus clientes y del usuario CENOA.</p>
      </div>
    </div>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

    <div class="portal-card">
      <h2>Nueva cuenta</h2>
      <form method="POST" action="/portal/admin/clientes">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="field--row">
          <div class="field">
            <label for="displayName">Nombre a mostrar</label>
            <input type="text" id="displayName" name="displayName" placeholder="Ej: Mascotas Center" required />
          </div>
          <div class="field">
            <label for="role">Tipo de acceso</label>
            <select id="role" name="role" required>
              <option value="client">Cliente (ve sus informes)</option>
              <option value="cenoa">CENOA (dashboard de contenidos)</option>
              <option value="admin">Administrador</option>
            </select>
          </div>
        </div>
        <div class="field--row">
          <div class="field">
            <label for="username">Usuario</label>
            <input type="text" id="username" name="username" placeholder="ej: mascotascenter" pattern="[a-z0-9._\-]{3,40}" required />
            <p class="field-hint">Minúsculas, sin espacios. Ej: mascotascenter</p>
          </div>
          <div class="field">
            <label for="password">Contraseña</label>
            <input type="text" id="password" name="password" placeholder="ej: mascotas2026" minlength="6" required />
          </div>
        </div>
        <div class="form-actions" style="max-width:220px;">
          <button type="submit" class="btn btn--primary">Crear cuenta</button>
        </div>
      </form>
    </div>

    <div class="portal-card">
      <h2>Cuentas existentes</h2>
      <div class="table-wrap">
        <table class="portal-table">
          <thead>
            <tr><th>Nombre</th><th>Usuario</th><th>Tipo</th><th>Informes</th><th>Creada</th><th>Acciones</th></tr>
          </thead>
          <tbody>
            <% users.forEach(function(u){ %>
            <tr>
              <td><%= u.displayName %></td>
              <td><%= u.username %></td>
              <td><span class="badge badge-<%= u.role %>"><%= u.role === 'client' ? 'Cliente' : (u.role === 'cenoa' ? 'CENOA' : 'Admin') %></span></td>
              <td><%= u.role === 'client' ? reportsCount(u.username) : '—' %></td>
              <td class="nowrap"><%= new Date(u.createdAt).toLocaleDateString('es-AR') %></td>
              <td class="nowrap">
                <a href="/portal/admin/clientes/<%= u.id %>/editar" class="btn btn--outline btn-xs">Editar</a>
                <form method="POST" action="/portal/admin/clientes/<%= u.id %>/eliminar" style="display:inline" onsubmit="return confirm('¿Eliminar la cuenta \'' + <%- JSON.stringify(u.username) %> + '\'? Esta acción no se puede deshacer.');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn-danger btn-xs">Eliminar</button>
                </form>
              </td>
            </tr>
            <% }); %>
            <% if (users.length === 0) { %>
            <tr><td colspan="6" class="empty-state">Todavía no creaste ninguna cuenta.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/foot') %>
