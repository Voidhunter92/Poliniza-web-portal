<%- include('../partials/head', { title: 'Dashboard CENOA' }) %>
<div class="portal-shell">
  <%- include('../partials/topbar', { user, adminTabs, activeTab }) %>
  <main class="portal-main">
    <div class="portal-header">
      <div>
        <h1>Dashboard CENOA</h1>
        <p>Cargá y editá los contenidos que CENOA va a revisar y aprobar.</p>
      </div>
      <a href="/portal/admin/cenoa/nuevo?year=<%= year %>&month=<%= month %>&tipo=<%= tipo %>" class="btn btn--primary">+ Nuevo contenido</a>
    </div>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

    <form method="GET" action="/portal/admin/cenoa" class="month-nav">
      <select name="year" onchange="this.form.submit()">
        <% [...new Set(months.map(m => m.year))].forEach(function(y){ %>
          <option value="<%= y %>" <%= y === year ? 'selected' : '' %>><%= y %></option>
        <% }); %>
      </select>
      <select name="month" onchange="this.form.submit()">
        <% months.filter(m => m.year === year).forEach(function(m){ %>
          <option value="<%= m.month %>" <%= m.month === month ? 'selected' : '' %>><%= m.label.split(' ')[0] %></option>
        <% }); %>
      </select>
      <input type="hidden" name="tipo" value="<%= tipo %>" />
    </form>

    <div class="tabs-inline">
      <a href="/portal/admin/cenoa?year=<%= year %>&month=<%= month %>&tipo=placa" class="<%= tipo === 'placa' ? 'active' : '' %>">Placas</a>
      <a href="/portal/admin/cenoa?year=<%= year %>&month=<%= month %>&tipo=video" class="<%= tipo === 'video' ? 'active' : '' %>">Videos</a>
    </div>

    <div class="portal-stats">
      <div class="portal-stat"><strong><%= items.length %></strong><span>Total</span></div>
      <div class="portal-stat"><strong><%= items.filter(i => i.estado === 'aprobado').length %></strong><span>Aprobados</span></div>
      <div class="portal-stat"><strong><%= items.filter(i => i.estado === 'desaprobado').length %></strong><span>Desaprobados</span></div>
      <div class="portal-stat"><strong><%= items.filter(i => i.estado === 'revisar').length %></strong><span>A revisar</span></div>
    </div>

    <div class="portal-card">
      <h2><%= tipo === 'placa' ? 'Placas' : 'Videos' %> — <%= monthLabel %></h2>
      <div class="table-wrap">
        <table class="portal-table">
          <thead>
            <tr>
              <th>Empresa</th><th>Título</th><th>Piezas</th><th>Pedido</th><th>Entrega</th>
              <th>Copy</th><th>Drive</th><th>Estado</th><th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(function(i){ %>
            <tr>
              <td><%= i.empresa %></td>
              <td><%= i.titulo %></td>
              <td><%= i.numPiezas %></td>
              <td class="nowrap"><%= i.fechaPedido || '—' %></td>
              <td class="nowrap"><%= i.fechaEntrega || '—' %></td>
              <td><div class="copy-cell"><%= i.copy || '—' %></div></td>
              <td><% if (i.driveLink) { %><a href="<%= i.driveLink %>" target="_blank" rel="noopener">Abrir</a><% } else { %>—<% } %></td>
              <td><span class="badge badge-<%= i.estado %>"><%= i.estado === 'aprobado' ? 'Aprobado' : (i.estado === 'desaprobado' ? 'Desaprobado' : 'A revisar') %></span></td>
              <td class="nowrap">
                <a href="/portal/admin/cenoa/<%= i.id %>/editar" class="btn btn--outline btn-xs">Editar</a>
                <form method="POST" action="/portal/admin/cenoa/<%= i.id %>/eliminar" style="display:inline" onsubmit="return confirm('¿Eliminar este contenido?');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn-danger btn-xs">Eliminar</button>
                </form>
              </td>
            </tr>
            <% }); %>
            <% if (items.length === 0) { %>
            <tr><td colspan="9" class="empty-state">No hay contenidos cargados para este mes.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/foot') %>
