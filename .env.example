# Puerto donde escucha el servidor. Coolify suele definirlo automáticamente.
PORT=3000

# Entorno: "production" activa cookies de sesión seguras (requiere HTTPS).
NODE_ENV=production

# Opcional: si no se define, el servidor genera y guarda una clave aleatoria
# en server/data/session-secret.txt en el primer arranque.
# SESSION_SECRET=
